// Cookie utility function
function getCookieSuperThanks(name) {
    var name = name + '=';
    var cookies = decodeURIComponent(document.cookie).split(';');
    for (var i = 0; i < cookies.length; i++) {
        var c = cookies[i];
        while (c.charAt(0) == ' ') {
            c = c.substring(1);
        }
        if (c.indexOf(name) == 0) {
            return c.substring(name.length, c.length);
        }
    }
    return '';
}

// Function to update submit button state
function updateSubmitButtonState() {
    const submitButton = document.getElementById('btn-submit');
    if (!submitButton) return;
    
    const customAmountInput = document.getElementById('customAmount');
    const selectedPriceInput = document.querySelector('input[name="price"]:checked');
    const selectedPaymentInput = document.querySelector('input[name="payment_type"]:checked');
    
    // Check if amount is valid (either custom amount >= 5000 or radio selected)
    let hasValidAmount = false;
    if (customAmountInput && customAmountInput.dataset.raw && Number(customAmountInput.dataset.raw) >= 5000) {
        hasValidAmount = true;
    } else if (selectedPriceInput && Number(selectedPriceInput.value) >= 5000) {
        hasValidAmount = true;
    }
    
    // Check if payment method is selected
    const hasPaymentMethod = !!selectedPaymentInput;
    
    // Enable button only if both conditions are met
    if (hasValidAmount && hasPaymentMethod) {
        submitButton.disabled = false;
    } else {
        submitButton.disabled = true;
    }
}

